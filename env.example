TOKEN=WKLEJ_TOKEN_BOTA
CLIENT_ID=WKLEJ_ID_APLIKACJI
GUILD_ID=WKLEJ_ID_SERWERA
TIME_ZONE=Europe/Warsaw
MAX_MESSAGES=25000

PAWEL_DROP_CHANNEL_ID=1515437409653756005
RYZEN_DROP_CHANNEL_ID=1524841513606189178

# Domyślnie raport jest wysyłany na ten sam kanał co dropy.
PAWEL_REPORT_CHANNEL_ID=1515437409653756005
RYZEN_REPORT_CHANNEL_ID=1524841513606189178

# Osoby pingowane przez alerty na odpowiednich kanałach.
PAWEL_ALERT_USER_ID=1265797244074852576
RYZEN_ALERT_USER_ID=1330652001075335300

# Sekrety adresów relay. Ustaw DWA różne, długie, losowe hasła.
# Nie wpisuj tutaj tokenu bota ani prawdziwego Discord webhooka.
PAWEL_INGEST_SECRET=ZMIEN_NA_DLUGI_LOSOWY_SEKRET_PAWEL
RYZEN_INGEST_SECRET=ZMIEN_NA_DLUGI_LOSOWY_SEKRET_RYZEN

# Zwykle bot sam użyje domeny Railway. Ustaw ręcznie tylko gdy trzeba.
# PUBLIC_BASE_URL=https://twoja-domena.up.railway.app
RELAY_BODY_LIMIT_BYTES=1000000
RELAY_DUPLICATE_WINDOW_MS=30000

# Alert przy RAP 4B ±100M, czyli od 3.9B do 4.1B.
ALERT_RAP_CENTER=4000000000
ALERT_RAP_TOLERANCE=100000000

# 0 = wyłączony. Przykład: 100000000 oznacza alert dla każdego peta >= 100M RAP.
ALERT_MIN_RAP=0

# Aktualne ceny i historia RAP z publicznego API PS99RAP.
PS99RAP_ENABLED=true
PS99RAP_BASE_URL=https://ps99rap.com
PS99RAP_CACHE_TTL_MS=120000
PS99RAP_TIMEOUT_MS=15000
PS99RAP_BULK_CHUNK_SIZE=40
PS99RAP_CATALOG_TTL_MS=1800000

# Dla Railway Volume ustaw mount path /app/data.
STATE_DIR=/app/data

# Kanały, na których bot automatycznie publikuje listy prywatnych serwerów Roblox
PAWEL_SERVER_CHANNEL_ID=1525508811039969480
RYZEN_SERVER_CHANNEL_ID=1525508845324075179

# Kanały Trading Plaza oraz kanały raportów o 23:59
PAWEL_PLAZA_CHANNEL_ID=1524784522154213397
RYZEN_PLAZA_CHANNEL_ID=1524841567028903966
PAWEL_PLAZA_REPORT_CHANNEL_ID=1524784522154213397
RYZEN_PLAZA_REPORT_CHANNEL_ID=1524841567028903966
